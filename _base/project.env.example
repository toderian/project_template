# Project Environment Configuration
# Copy this file to project.env at the repo root, then fill in your local paths:
#   cp _base/project.env.example project.env
# project.env is gitignored and read by installer scripts at the repo root.

# --- Repo paths ---

# Path to this project root (auto-detected by scripts, override if needed)
# PROJECT_ROOT=/home/you/repos/project_template

# Path to the planning framework repo (used for syncing shared playbook resources)
PLANNING_FRAMEWORK_REPO=/home/you/repos/vi_planning_framework

# --- Codex configuration ---

# Codex home directory (default: ~/.codex)
# CODEX_HOME=~/.codex

# Codex local plugin install directory (default: ~/plugins)
# CODEX_PLUGINS_DIR=/home/you/plugins

# Codex local marketplace path (default: ~/.agents/plugins/marketplace.json)
# CODEX_MARKETPLACE_PATH=/home/you/.agents/plugins/marketplace.json

# Local marketplace metadata used when creating a new marketplace file
CODEX_MARKETPLACE_NAME=local-project-template
CODEX_MARKETPLACE_DISPLAY_NAME="Local Project Template"

# --- Context docs ---

# Where CONTEXT.md docs are stored. Read by `describe-component` (component/architecture
# docs) and `grill-with-docs` (the domain glossary). Both follow the same rule:
#   * Unset (default): docs live in the repo being described — the domain CONTEXT.md at
#     the repo root, component CONTEXT.md co-located next to the code. Best when you own
#     the repo.
#   * Set to a directory: docs are gathered there instead, namespaced by source repo
#     ($CONTEXT_DOCS_DIR/<source-repo>/CONTEXT.md, .../<component>/CONTEXT.md). Use this
#     when the repo you're describing is template-inherited, vendored, or otherwise not
#     yours to commit to — pointing this at your own repo keeps the docs under your
#     control instead of polluting someone else's tree.
# CONTEXT_DOCS_DIR=docs/context

# --- Project preferences ---

# Default model for subagent dispatch (haiku, sonnet, opus)
DEFAULT_IMPLEMENTER_MODEL=sonnet
DEFAULT_REVIEWER_MODEL=inherit

# Git branch naming prefix
BRANCH_PREFIX=feat
