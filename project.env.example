# Project Environment Configuration
# Copy this file to project.env and fill in your local paths.
# project.env is gitignored and read by scripts and hooks.

# --- Repo paths ---

# Path to this project root (auto-detected by scripts, override if needed)
# PROJECT_ROOT=/home/you/repos/project_template

# Path to the planning framework repo (used for syncing shared playbook resources)
PLANNING_FRAMEWORK_REPO=/home/you/repos/vi_planning_framework

# --- Codex configuration ---

# Codex home directory (default: ~/.codex)
# CODEX_HOME=~/.codex

# --- Project preferences ---

# Default model for subagent dispatch (haiku, sonnet, opus)
DEFAULT_IMPLEMENTER_MODEL=sonnet
DEFAULT_REVIEWER_MODEL=inherit

# Git branch naming prefix
BRANCH_PREFIX=feat
