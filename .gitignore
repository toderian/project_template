.idea
.codex
# Local-only machine bindings (repos.map, runbook placeholders, environment notes).
.local/
.no-commit/
.worktrees/
worktrees/
.temp/
.tmp/
temp/
tmp/

# Local credentials for agent/tool use. Never commit.
.creds/

# Local Python virtual environments. Commit uv metadata, never the env itself.
.venv/
tools/python/.venv/

# Local environment config (copy from project.env.example)
project.env

# Agent runtime artifacts (start from templates/ when needed)
AGENT_PROGRESS.md
AGENT_TASKS.json
AGENT_DECISIONS.md

# GitHub triage knowledge base (repo-specific, not template content)
.out-of-scope/

# Local Claude Code settings (per-machine permission allowlist, hooks, etc.)
.claude/settings.local.json
